{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium",
        "image": "macos-sequoia-15.6-xcode-26.2"
      },
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.1"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "4q24thrh7q@privaterelay.appleid.com",
        "ascAppId": "6762173287"
      }
    }
  }
}